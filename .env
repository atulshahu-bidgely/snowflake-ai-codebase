SERVER_PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (React) - must be prefixed with REACT_APP_
REACT_APP_BACKEND_URL=http://localhost:3001

# Snowflake connection
SNOWFLAKE_ACCOUNT=NHLHDIP-BIDGELY_EAST
SNOWFLAKE_HOST=NHLHDIP-BIDGELY_EAST.snowflakecomputing.com
SNOWFLAKE_PAT=<PAT>
# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<key>
LANGSMITH_PROJECT="Energy_Assistant_2.0"
# Database context
SNOWFLAKE_DATABASE=snowflake_intelligence
SNOWFLAKE_SCHEMA=agents
SNOWFLAKE_WAREHOUSE=wh_agent_demo
SNOWFLAKE_ROLE=role_agent_demo

# Agent to invoke
AGENT_NAME=snowflake_intelligence.agents.energy_ami_agent_demo
AGENT_ENDPOINT=https://NHLHDIP-BIDGELY_EAST.snowflakecomputing.com/api/v2/cortex/agent:run
